# ============================================================
# points-mall-data — Environment Variables Reference
# Copy this file to .env.dev / .env.test / .env.prod and fill in real values.
# NEVER commit files with real secrets to Git.
# ============================================================

# ── Application ─────────────────────────────────────────────
PORT=8083
# Controls which .env.{ENVIRONMENT} file is loaded: dev | test | prod
ENVIRONMENT=dev

# ── PostgreSQL (Neon) ───────────────────────────────────────
# Get the pooler hostname from: Neon Dashboard → your branch → Connection string
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_SSL_PARAMS=?sslmode=require

# ── Internal BFF URL (for ETL pull) ─────────────────────────
BFF_INTERNAL_URL=http://localhost:4000
